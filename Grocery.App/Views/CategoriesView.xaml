<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             xmlns:m="clr-namespace:Grocery.Core.Models;assembly=Grocery.Core"
             x:Class="Grocery.App.Views.CategoriesView"
             x:DataType="vm:CategoriesViewModel"
             Title="Categoriëen">

    <CollectionView ItemsSource="{Binding Categories}"
                    SelectionMode="Single"
                    SelectionChanged="OnCategorySelected">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="m:Category">
                <Frame Padding="10" Margin="10,5">
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" FontSize="Medium" FontAttributes="Bold" />
                        <Label Text="{Binding Id, StringFormat='ID: {0}'}" FontSize="Small" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>